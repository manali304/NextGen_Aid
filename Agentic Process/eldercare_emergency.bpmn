            <uipath:input name="folderPath" type="string" value="=bindings.biZmGZWf7" />
            <uipath:input name="_label" type="string" value="CaregiverCheckin" />
            <uipath:input name="taskTitle" type="string" value="=vars.caregiverOutcome" required="true" />
            <uipath:input name="assignmentCriteria" type="string" value="SingleUser" />
            <uipath:input name="recipient" type="json" />
            <uipath:input name="customAssignees" type="string" />
