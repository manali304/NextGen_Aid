    <bpmn:userTask id="task_human_approve" name="APPROVE&#10;Ambulance Dispatch">
      <bpmn:documentation>Medical coordinator reviews AI assessment and approves or rejects ambulance dispatch. Form fields: ambulance_approved (bool), responding_hospital (string), coordinator_notes (text)</bpmn:documentation>
