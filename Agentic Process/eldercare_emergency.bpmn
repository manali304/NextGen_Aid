          <uipath:output name="blood_pressure" type="string" source="=blood_pressure" var="bloodPressure" />
          <uipath:output name="consciousness" type="string" source="=consciousness" var="consciousness" />
          <uipath:output name="injury_visible" type="string" source="=injury_visible" var="injuryVisible" />
          <uipath:output name="vitals_notes" type="string" source="=vitals_notes" var="vitalsNotes" />
          <uipath:output name="Action" type="string" source="=Action" var="action3" options="[{&#34;value&#34;:&#34;Completed&#34;,&#34;label&#34;:&#34;Completed&#34;}]" />
          <uipath:output name="hitlTask" type="jsonSchema" source="=hitlTask" var="hitlTask3" />
