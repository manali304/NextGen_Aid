    <bpmn:serviceTask id="task_monitor_arrival" name="Track Ambulance&#10;Arrival">
      <bpmn:documentation>Robot polls ambulance ETA and updates dashboard. Outputs: arrived_at, arrival_confirmed</bpmn:documentation>
