          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error2" />
          <uipath:output name="ambulance_approved" type="string" source="=ambulance_approved" var="ambulanceApproved" />
          <uipath:output name="coordinator_notes" type="string" source="=coordinator_notes" var="coordinatorNotes" />
          <uipath:output name="Action" type="string" source="=Action" var="action2" options="[{&#34;value&#34;:&#34;SubmitDecision&#34;,&#34;label&#34;:&#34;SubmitDecision&#34;}]" />
