      <bpmn:outgoing>flow_checkin_to_gw5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_outcome" name="Outcome?" default="flow_outcome_resolved">
      <bpmn:incoming>flow_checkin_to_gw5</bpmn:incoming>
      <bpmn:outgoing>flow_outcome_resolved</bpmn:outgoing>
      <bpmn:outgoing>flow_outcome_escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_review" name="Review Suspicious&#10;Alert">
      <bpmn:documentation>Supervisor reviews flagged alert. Decision: genuine or false_alarm</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Actions.HITL" version="v2" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.bx5l2mBrL" />
            <uipath:input name="folderPath" type="string" value="=bindings.bGV5K38Ct" />
            <uipath:input name="_label" type="string" value="Review Suspicious Alert" />
            <uipath:input name="taskTitle" type="string" value="=vars.reviewerDecision" required="true" />
            <uipath:input name="assignmentCriteria" type="string" value="SingleUser" />
            <uipath:input name="recipient" type="json" />
            <uipath:input name="customAssignees" type="string" />
            <uipath:input name="priority" type="string" value="Medium" />
            <uipath:input name="labels" type="string" />
            <uipath:input name="actionCatalogName" type="string" />
            <uipath:input name="enableActionableNotifications" type="boolean" value="false" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"case_id":{"type":"string"},"in_ElderId":{"type":"string"},"out_Source":{"type":"string"},"received_at":{"type":"string"},"in_RawText":{"type":"string"},"out_Reason":{"type":"string"},"fraud_confidence":{"type":"number"},"emergency_confidence":{"type":"number"},"out_SeverityScore":{"type":"number"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="HitlTaskArguments" type="json" target="bodyField"><![CDATA[{"case_id":null,"in_ElderId":null,"out_Source":null,"received_at":null,"in_RawText":null,"out_Reason":null,"fraud_confidence":null,"emergency_confidence":null,"out_SeverityScore":null}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error" />
          <uipath:output name="reviewer_decision" type="string" source="=reviewer_decision" var="reviewerDecision" />
          <uipath:output name="notes" type="string" source="=notes" var="notes" />
          <uipath:output name="Action" type="string" source="=Action" var="action" options="[{&#34;value&#34;:&#34;SubmitReviewDecision&#34;,&#34;label&#34;:&#34;SubmitReviewDecision&#34;}]" />
          <uipath:output name="hitlTask" type="jsonSchema" source="=hitlTask" var="hitlTask" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw2_to_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_to_gw6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_review_decision" name="Decision?" default="flow_review_false">
      <bpmn:incoming>flow_review_to_gw6</bpmn:incoming>
      <bpmn:outgoing>flow_review_genuine</bpmn:outgoing>
      <bpmn:outgoing>flow_review_false</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_close_case" name="Close Case &#38;&#10;Save Audit Trail">
      <bpmn:documentation>Robot saves complete case audit log to database and marks Maestro case as resolved</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v2" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.bFNXKR5bG" />
            <uipath:input name="folderPath" type="string" value="=bindings.bM5NGU5XS" />
            <uipath:input name="_label" type="string" value="CaseCloser" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"in_CaseId":{"type":"string"},"in_Outcome":{"type":"string"},"in_DispatchId":{"type":"string"},"in_CaregiverId":{"type":"string"},"in_ResolutionNotes":{"type":"string"},"in_ApiBaseUrl":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"in_CaseId":null,"in_Outcome":null,"in_DispatchId":null,"in_CaregiverId":null,"in_ResolutionNotes":null,"in_ApiBaseUrl":null}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error12" />
          <uipath:output name="out_AuditLogUrl" type="string" source="=out_AuditLogUrl" var="outAuditLogUrl" />
          <uipath:output name="out_ClosedAt" type="string" source="=out_ClosedAt" var="outClosedAt" />
          <uipath:output name="out_CaseNumber" type="string" source="=out_CaseNumber" var="outCaseNumber" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_monitor_to_resolve</bpmn:incoming>
      <bpmn:incoming>flow_outcome_resolved</bpmn:incoming>
      <bpmn:outgoing>flow_close_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_resolved" name="Case&#10;Resolved ✅">
      <bpmn:incoming>flow_close_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_dismissed" name="Alert&#10;Dismissed">
      <bpmn:incoming>flow_gw1_to_dismiss</bpmn:incoming>
      <bpmn:incoming>flow_review_false</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_escalated" name="Escalated to&#10;Critical Path">
      <bpmn:incoming>flow_outcome_escalate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_detect" sourceRef="start_event" targetRef="task_detect" />
    <bpmn:sequenceFlow id="flow_detect_to_gw1" sourceRef="task_detect" targetRef="gw_is_emergency" />
    <bpmn:sequenceFlow id="flow_gw1_to_fraud" name="Yes — emergency" sourceRef="gw_is_emergency" targetRef="task_fraud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${is_emergency}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw1_to_dismiss" name="No — dismiss" sourceRef="gw_is_emergency" targetRef="end_dismissed" />
    <bpmn:sequenceFlow id="flow_fraud_to_gw2" sourceRef="task_fraud" targetRef="gw_suspicious" />
    <bpmn:sequenceFlow id="flow_gw2_to_review" name="Suspicious" sourceRef="gw_suspicious" targetRef="task_review">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${is_suspicious}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw2_to_severity" name="Clear" sourceRef="gw_suspicious" targetRef="task_severity" />
    <bpmn:sequenceFlow id="flow_severity_to_gw3" sourceRef="task_severity" targetRef="gw_severity" />
    <bpmn:sequenceFlow id="flow_sev_critical" name="Severity &#62;= 4" sourceRef="gw_severity" targetRef="pgw_split_critical">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${severity_score &gt;= 4}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_sev_standard" name="Severity less than 4" sourceRef="gw_severity" targetRef="pgw_split_standard" />
    <bpmn:sequenceFlow id="flow_par_hospital" sourceRef="pgw_split_critical" targetRef="task_hospital" />
    <bpmn:sequenceFlow id="flow_par_notify_critical" sourceRef="pgw_split_critical" targetRef="task_notify_critical" />
    <bpmn:sequenceFlow id="flow_par_assign_cg_critical" sourceRef="pgw_split_critical" targetRef="task_assign_cg" />
    <bpmn:sequenceFlow id="flow_hospital_to_join" sourceRef="task_hospital" targetRef="pgw_join_critical" />
    <bpmn:sequenceFlow id="flow_notify_critical_to_join" sourceRef="task_notify_critical" targetRef="pgw_join_critical" />
    <bpmn:sequenceFlow id="flow_assign_cg_to_join" sourceRef="task_assign_cg" targetRef="pgw_join_critical" />
    <bpmn:sequenceFlow id="flow_join_to_human" sourceRef="pgw_join_critical" targetRef="task_human_approve" />
    <bpmn:sequenceFlow id="flow_human_to_gw4" sourceRef="task_human_approve" targetRef="gw_approved" />
    <bpmn:sequenceFlow id="flow_approved_yes" name="Approved" sourceRef="gw_approved" targetRef="task_dispatch">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${ambulance_approved}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_approved_no" name="Declined" sourceRef="gw_approved" targetRef="pgw_split_standard" />
    <bpmn:sequenceFlow id="flow_dispatch_to_track" sourceRef="task_dispatch" targetRef="task_notify_dispatch" />
    <bpmn:sequenceFlow id="flow_notify_dispatch_to_monitor" sourceRef="task_notify_dispatch" targetRef="task_monitor_arrival" />
    <bpmn:sequenceFlow id="flow_monitor_to_resolve" sourceRef="task_monitor_arrival" targetRef="task_close_case" />
    <bpmn:sequenceFlow id="flow_std_assign" sourceRef="pgw_split_standard" targetRef="task_assign_standard" />
    <bpmn:sequenceFlow id="flow_std_notify" sourceRef="pgw_split_standard" targetRef="task_notify_standard" />
    <bpmn:sequenceFlow id="flow_std_assign_join" sourceRef="task_assign_standard" targetRef="pgw_join_standard" />
    <bpmn:sequenceFlow id="flow_std_notify_join" sourceRef="task_notify_standard" targetRef="pgw_join_standard" />
    <bpmn:sequenceFlow id="flow_std_join_to_checkin" sourceRef="pgw_join_standard" targetRef="task_caregiver_checkin" />
    <bpmn:sequenceFlow id="flow_checkin_to_gw5" sourceRef="task_caregiver_checkin" targetRef="gw_outcome" />
    <bpmn:sequenceFlow id="flow_outcome_resolved" name="Resolved" sourceRef="gw_outcome" targetRef="task_close_case" />
    <bpmn:sequenceFlow id="flow_outcome_escalate" name="Needs escalation" sourceRef="gw_outcome" targetRef="end_escalated">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${caregiver_outcome == "needs_escalation"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_review_to_gw6" sourceRef="task_review" targetRef="gw_review_decision" />
    <bpmn:sequenceFlow id="flow_review_genuine" name="Genuine" sourceRef="gw_review_decision" targetRef="task_severity">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${reviewer_decision == "genuine"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_review_false" name="False alarm" sourceRef="gw_review_decision" targetRef="end_dismissed" />
    <bpmn:sequenceFlow id="flow_close_to_end" sourceRef="task_close_case" targetRef="end_resolved" />
  </bpmn:process>
