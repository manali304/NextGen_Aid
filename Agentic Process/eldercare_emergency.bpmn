      <bpmn:outgoing>flow_approved_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_approved_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_dispatch" name="DispatchAmbulance ">
      <bpmn:documentation>Robot contacts ambulance service, confirms dispatch, and starts tracking ETA</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
